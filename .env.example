# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno requeridas para ejecutar la suite de pruebas ETRM QA
#
# INSTRUCCIONES:
#   1. Copia este archivo como ".env" en la raíz del proyecto:
#        cp .env.example .env
#   2. Rellena cada variable con el valor real correspondiente.
#   3. NUNCA subas el archivo ".env" a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# URL base del aplicativo ETRM
ETRM_BASE_URL=https://etrm-qa.enersinc.com/

# Token de bypass antibot proporcionado por el equipo de infraestructura
ETRM_ANTIBOT_TOKEN=<token_proporcionado_por_infraestructura>

# Credenciales del usuario de prueba
ETRM_TEST_EMAIL=<email_de_prueba@enersinc.com>
ETRM_TEST_PASSWORD=<contraseña_de_prueba>
